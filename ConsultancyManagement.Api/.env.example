ASPNETCORE_ENVIRONMENT=Production
PORT=8000

# Required in Production (appsettings.Production.json lists none — env must set your SPA URL(s)).
Cors__AllowedOrigins__0=https://mydomain.com
Cors__AllowedOrigins__1=https://www.mydomain.com

# Prefer DATABASE_URL in production; keep ConnectionStrings__DefaultConnection as fallback.
# Example:
# DATABASE_URL=Host=my-rds.xxxxx.us-east-1.rds.amazonaws.com;Port=5432;Database=consultancy_prod;Username=app_user;Password=CHANGE_ME;SSL Mode=Require;Trust Server Certificate=true
DATABASE_URL=
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ConsultancyManagementDb;Username=postgres;Password=CHANGE_ME

Jwt__Key=CHANGE_ME_SUPER_SECRET_KEY_MIN_32_CHARS
Jwt__Issuer=ConsultancyManagement
Jwt__Audience=ConsultancyManagementUsers
Jwt__ExpiryMinutes=120

# ---- Password reset (optional; recommended in production / AWS) ----
# Canonical SPA reset URL so emailed links always use your real HTTPS domain (CloudFront, etc.).
# PasswordReset__PublicResetUrlBase=https://applabs.consultancymanagementsolutions.com/reset-password

# ---- SMTP (password reset + any future mail) ----
# All mail uses the same From address. Set these on the server; do not commit real secrets.
# FromEmail: must be allowed by your provider (e.g. verified domain in SES, or your Gmail for app passwords).
#
# Examples (Host / typical port / notes):
#   Gmail:     smtp.gmail.com  587  — use an App Password, not your normal Google password
#   Outlook:   smtp.office365.com  587
#   SendGrid:  smtp.sendgrid.net  587  — Username "apikey", Password = your API key
#   AWS SES:   email-smtp.<region>.amazonaws.com  587  — use SMTP creds from SES; verify From domain/email in SES
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-smtp-username
Smtp__Password=your-smtp-password
Smtp__FromEmail=noreply@yourdomain.com
Smtp__FromName=ConsultancyManagement Solutions
Smtp__EnableSsl=true
