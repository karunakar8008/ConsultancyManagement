# Copy to `.env` in the repo root (same folder as docker-compose.prod.yml).
# Never commit `.env`.

# --- PostgreSQL (Docker Compose internal DB) ---
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_PASSWORD

# --- JWT (required; min 32 chars in Production) ---
Jwt__Key=CHANGE_ME_SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG
Jwt__Issuer=ConsultancyManagement
Jwt__Audience=ConsultancyManagementUsers
Jwt__ExpiryMinutes=120

# --- CORS: must include the exact browser origin of your SPA (scheme + host [+ port]) ---
# Same-origin Docker deploy (nginx serves UI + proxies /api): use your public URL.
# Examples:
#   Cors__AllowedOrigins__0=https://applabs.consultancymanagementsolutions.com
#   Cors__AllowedOrigins__1=https://www.consultancymanagementsolutions.com
# Testing over plain HTTP:
#   Cors__AllowedOrigins__0=http://YOUR_SERVER_IP
Cors__AllowedOrigins__0=https://your-spa-public-url.example.com

# --- Swagger (optional; default off in Production) ---
# EnableSwagger=false

# --- Password reset links in email (strongly recommended on AWS / CloudFront) ---
# Must be the HTTPS URL of your SPA reset page (no trailing slash before query string).
# When set, the API ignores the browser-sent resetUrlBase so mail always matches your real domain.
# PasswordReset__PublicResetUrlBase=https://applabs.consultancymanagementsolutions.com/reset-password

# --- SMTP (password reset & mail) ---
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=
Smtp__Password=
Smtp__FromEmail=
Smtp__FromName=ConsultancyManagement Solutions
Smtp__EnableSsl=true

# --- Compose: optional host port for nginx (default 80) ---
# HTTP_PORT=80
